+    <div class="group-row" data-phone="${escapeHtml(m.phone)}">
+      <span class="status-dot ${m.active ? "active" : "pending"}"></span>
+      <div class="group-info">
+        <div class="group-name">${escapeHtml(m.name || m.phone)}</div>
+        <div class="group-jid">${escapeHtml(m.phone)}</div>
+      </div>
+      <div class="group-actions">
+        <div class="toggle ${m.active ? "on" : ""}" title="${m.active ? "Aktif — klik untuk nonaktifkan" : "Nonaktif — klik untuk aktifkan"}">
+          <div class="knob"></div>
+        </div>
+        <button class="btn-icon" title="Hapus anggota">Hapus</button>
+      </div>
+    </div>
+  `).join("");
+
+  list.querySelectorAll(".toggle").forEach((el, i) => {
+    el.addEventListener("click", () => toggleMember(members[i]));
+  });
+  list.querySelectorAll(".btn-icon").forEach((el, i) => {
+    el.addEventListener("click", () => deleteMember(members[i]));
+  });
+}
+
+async function loadMembers() {
+  const res = await apiFetch("/api/members");
+  if (res.status === 401) {
+    window.location.href = "index.html";
+    return;
+  }
+  const data = await res.json();
+  members = data.members || [];
+  renderMembers();
+  document.getElementById("stat-members").textContent = members.filter(m => m.active).length;
+}
+
+async function toggleMember(member) {
+  const res = await apiFetch(`/api/members/${encodeURIComponent(member.phone)}/active`, {
+    method: "PATCH",
+    body: JSON.stringify({ active: !member.active }),
+  });
+  if (res.ok) {
+    showToast(member.active ? "Anggota dinonaktifkan." : "Anggota diaktifkan.");
+    loadMembers();
+  } else {
+    showToast("Gagal mengubah status anggota.");
+  }
+}
+
+async function deleteMember(member) {
+  if (!confirm(`Hapus anggota "${member.name || member.phone}" dari daftar?`)) return;
+  const res = await apiFetch(`/api/members/${encodeURIComponent(member.phone)}`, { method: "DELETE" });
